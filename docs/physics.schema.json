{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/fem/physics.schema.json",
  "title": "FEM Multi-Physics Project Configuration",
  "type": "object",
  "required": ["simulation", "fields"],
  "properties": {
    "$schema": { "type": "string" },
    "simulation": {
      "type": "object",
      "required": ["mesh_path"],
      "properties": {
        "mesh_path": { "type": "string" },
        "order": { "type": "integer", "minimum": 1, "default": 1 },
        "uniform_refinement_levels": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "output_dir": { "type": "string", "default": "results" },
        "solver": {
          "type": "string",
          "enum": ["pcg", "mumps", "pardiso"],
          "default": "pcg",
          "description": "Default linear solver for all fields."
        },
        "solver_electrostatic": {
          "type": "string",
          "enum": ["pcg", "umfpack", "mumps", "pardiso"],
          "description": "Override solver for the electrostatic field. If omitted, uses 'solver'."
        },
        "solver_thermal": {
          "type": "string",
          "enum": ["pcg", "umfpack", "mumps", "pardiso"],
          "description": "Override solver for the thermal field. If omitted, uses 'solver'."
        },
        "solver_mechanical": {
          "type": "string",
          "enum": ["pcg", "umfpack", "mumps", "pardiso"],
          "description": "Override solver for the mechanical field. If omitted, uses 'solver'."
        },
        "picard_max_iterations": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "picard_tolerance": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1e-6
        },
        "picard_relaxation": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "default": 1.0
        },
        "transient_enabled": {
          "type": "boolean",
          "default": false
        },
        "transient_t_start": {
          "type": "number",
          "default": 0.0
        },
        "transient_t_end": {
          "type": "number",
          "default": 1.0
        },
        "transient_dt": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1.0
        },
        "transient_output_interval": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 10.0,
          "description": "Time interval between output snapshots. Only snapshots at multiples of this interval are written to the transient text file."
        },
        "adaptive_dt": {
          "type": "boolean",
          "default": false,
          "description": "Enable predictor-corrector adaptive time stepping with WRMS error control."
        },
        "adaptive_reltol": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1e-3,
          "description": "Relative tolerance for WRMS adaptive time step error norm."
        },
        "adaptive_abstol": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1e-6,
          "description": "Absolute tolerance for WRMS adaptive time step error norm."
        },
        "dt_min": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1e-6,
          "description": "Minimum allowed time step when adaptive_dt is enabled."
        },
        "dt_max": {
          "type": "number",
          "minimum": 0.0,
          "default": 0.0,
          "description": "Maximum allowed time step. 0 means use transient_output_interval."
        },
        "eta_safety": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "default": 0.9,
          "description": "Safety factor for adaptive time step scaling."
        },
        "eta_max": {
          "type": "number",
          "exclusiveMinimum": 1.0,
          "default": 2.0,
          "description": "Maximum growth factor for adaptive time step."
        },
        "eta_min": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "default": 0.2,
          "description": "Minimum shrink factor for adaptive time step."
        },
        "log_level": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error", "critical"],
          "default": "info"
        },
        "comsol_reference_path": {
          "type": "string",
          "default": "",
          "description": "Path to COMSOL reference result file for automatic comparison after solve. Leave empty to skip comparison."
        },
        "compare_args": {
          "type": "string",
          "default": "",
          "description": "Extra arguments to pass to the comparison script (e.g. '--transient --field-names V,T,disp')."
        }
      },
      "additionalProperties": false
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "properties": {
            "type": "object",
            "description": "Property expression strings, e.g. diffusion='1.0', k='10+0.1*x'."
          }
        },
        "additionalProperties": false
      }
    },
    "domain_materials": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "integer", "minimum": 1 }
      },
      "description": "Map material name to domain attribute list. Used for piecewise diffusion assignment."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["electrostatic", "thermal", "mechanical"]
          },
          "source_default": { "type": "string", "default": "0.0" },
          "source_by_domain": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Domain attribute -> source expression"
          },
          "dirichlet_boundary_conditions": {
            "type": "array",
            "description": "Boundary-wise Dirichlet conditions for scalar fields (can set different values on different boundary attribute sets).",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": {
                  "oneOf": [
                    { "type": "number" },
                    {
                      "type": "string",
                      "description": "muparser expression with variable t for time-varying boundary conditions, e.g. '0.02*sin(100*pi*t)'"
                    }
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "robin_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "l", "q"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "l": { "type": "number" },
                "q": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "body_force_default": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "default": [0.0, 0.0, 0.0]
          },
          "body_force_by_domain": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3
            }
          },
          "pressure_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "displacement_boundary_conditions": {
            "type": "array",
            "description": "Strongly enforce vector displacement on selected boundaries.",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "default": [0.0, 0.0, 0.0]
                }
              },
              "additionalProperties": false
            }
          },
          "normal_displacement_boundary_conditions": {
            "type": "array",
            "description": "Weakly enforce u·n = 0 on selected boundaries using a penalty term.",
            "items": {
              "type": "object",
              "required": ["bdr_attributes"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "penalty": { "type": "number", "default": 1.0e12 }
              },
              "additionalProperties": false
            }
          },
          "initial_temperature": {
            "type": "number",
            "default": 293.15,
            "description": "Initial temperature for transient thermal fields, and for steady-state thermal fields if no other initial condition is specified."
          },
          "reference_temperature": {
            "type": "number",
            "default": 293.15,
            "description": "Reference temperature for thermal expansion for mechanical fields and sigma for electrostatic fields. Only used if thermal fields are not enabled."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
