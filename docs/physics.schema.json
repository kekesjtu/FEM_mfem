{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/fem/physics.schema.json",
  "title": "FEM Multi-Physics Project Configuration",
  "type": "object",
  "required": ["simulation", "fields"],
  "properties": {
    "$schema": { "type": "string" },
    "simulation": {
      "type": "object",
      "required": ["mesh_path"],
      "properties": {
        "mesh_path": { "type": "string" },
        "order": { "type": "integer", "minimum": 1, "default": 1 },
        "uniform_refinement_levels": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "output_dir": { "type": "string", "default": "results" },
        "solver": {
          "type": "string",
          "enum": ["pcg", "amgcl", "umfpack", "umpack"],
          "default": "pcg"
        },
        "log_level": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error", "critical"],
          "default": "info"
        }
      },
      "additionalProperties": false
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "properties"],
        "properties": {
          "name": { "type": "string" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Property expression strings, e.g. diffusion='1.0', k='10+0.1*x'."
          }
        },
        "additionalProperties": false
      }
    },
    "domain_materials": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "integer", "minimum": 1 }
      },
      "description": "Map material name to domain attribute list. Used for piecewise diffusion assignment."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["electrostatic", "thermal", "mechanical"]
          },
          "source": { "type": "string", "default": "0.0" },
          "source_default": { "type": "string", "default": "0.0" },
          "source_by_domain": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Domain attribute -> source expression"
          },
          "dirichlet_value": { "type": "number", "default": 0.0 },
          "dirichlet_bdr_attributes": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "default": []
          },
          "dirichlet_boundary_conditions": {
            "type": "array",
            "description": "Boundary-wise Dirichlet conditions for scalar fields (can set different values on different boundary attribute sets).",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "robin_l": { "type": "number", "default": 0.0 },
          "robin_q": { "type": "number", "default": 0.0 },
          "robin_bdr_attributes": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "default": []
          },
          "robin_on_remaining_boundaries": {
            "type": "boolean",
            "default": false
          },
          "robin_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "l", "q"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "l": { "type": "number" },
                "q": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "body_force_default": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "default": [0.0, 0.0, 0.0]
          },
          "body_force_by_domain": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3
            }
          },
          "dirichlet_displacement_value": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "default": [0.0, 0.0, 0.0]
          },
          "traction_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3
                }
              },
              "additionalProperties": false
            }
          },
          "pressure_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "normal_displacement_boundary_conditions": {
            "type": "array",
            "description": "Weakly enforce u·n = 0 on selected boundaries using a penalty term.",
            "items": {
              "type": "object",
              "required": ["bdr_attributes"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "penalty": { "type": "number", "default": 1.0e12 }
              },
              "additionalProperties": false
            }
          },
          "reference_temperature": {
            "type": "number",
            "default": 293.15
          },
          "enable_thermal_strain_coupling": {
            "type": "boolean",
            "default": true
          },
          "enable_stress_postprocess": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
