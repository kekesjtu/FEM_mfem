{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/fem/physics.schema.json",
  "title": "FEM Multi-Physics Project Configuration",
  "type": "object",
  "required": ["simulation", "fields"],
  "properties": {
    "$schema": { "type": "string" },
    "simulation": {
      "type": "object",
      "required": ["mesh_path"],
      "properties": {
        "mesh_path": { "type": "string" },
        "order": { "type": "integer", "minimum": 1, "default": 1 },
        "uniform_refinement_levels": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "output_dir": { "type": "string", "default": "results" },
        "solver": {
          "type": "string",
          "enum": ["pcg", "umfpack"],
          "default": "pcg"
        },
        "picard_max_iterations": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "picard_tolerance": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1e-6
        },
        "picard_relaxation": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "default": 1.0
        },
        "transient_enabled": {
          "type": "boolean",
          "default": false
        },
        "transient_t_start": {
          "type": "number",
          "default": 0.0
        },
        "transient_t_end": {
          "type": "number",
          "default": 1.0
        },
        "transient_dt": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 1.0
        },
        "transient_output_interval": {
          "type": "number",
          "exclusiveMinimum": 0.0,
          "default": 10.0,
          "description": "Time interval between output snapshots. Only snapshots at multiples of this interval are written to the transient text file."
        },
        "adaptive_dt": {
          "type": "boolean",
          "default": false,
          "description": "Enable adaptive time stepping. When Picard iteration fails to converge, dt is halved and the step is retried. When convergence is fast, dt is increased."
        },
        "log_level": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error", "critical"],
          "default": "info"
        }
      },
      "additionalProperties": false
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "properties"],
        "properties": {
          "name": { "type": "string" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Property expression strings, e.g. diffusion='1.0', k='10+0.1*x'."
          }
        },
        "additionalProperties": false
      }
    },
    "domain_materials": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "integer", "minimum": 1 }
      },
      "description": "Map material name to domain attribute list. Used for piecewise diffusion assignment."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["electrostatic", "thermal", "mechanical"]
          },
          "source_default": { "type": "string", "default": "0.0" },
          "source_by_domain": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Domain attribute -> source expression"
          },
          "dirichlet_boundary_conditions": {
            "type": "array",
            "description": "Boundary-wise Dirichlet conditions for scalar fields (can set different values on different boundary attribute sets).",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "robin_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "l", "q"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "l": { "type": "number" },
                "q": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "body_force_default": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "default": [0.0, 0.0, 0.0]
          },
          "body_force_by_domain": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3
            }
          },
          "pressure_boundary_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "displacement_boundary_conditions": {
            "type": "array",
            "description": "Strongly enforce vector displacement on selected boundaries.",
            "items": {
              "type": "object",
              "required": ["bdr_attributes", "value"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "value": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "default": [0.0, 0.0, 0.0]
                }
              },
              "additionalProperties": false
            }
          },
          "normal_displacement_boundary_conditions": {
            "type": "array",
            "description": "Weakly enforce u·n = 0 on selected boundaries using a penalty term.",
            "items": {
              "type": "object",
              "required": ["bdr_attributes"],
              "properties": {
                "bdr_attributes": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 1 }
                },
                "penalty": { "type": "number", "default": 1.0e12 }
              },
              "additionalProperties": false
            }
          },
          "reference_temperature": {
            "type": "number",
            "default": 293.15,
            "description": "Reference temperature (K). For mechanical fields: used as stress-free temperature in thermal expansion. For electrostatic fields: used as the initial/fallback temperature when evaluating temperature-dependent conductivity expressions (e.g. before coupling or in single-field mode). Default is 293.15 K (20 °C)."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
